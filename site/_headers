# Security headers applied to every route.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://player.vimeo.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://i.vimeocdn.com https://i.ytimg.com; font-src 'self'; connect-src 'self' https://player.vimeo.com https://vimeo.com; frame-src https://player.vimeo.com https://www.youtube.com https://www.youtube-nocookie.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'

# Static asset caching — long immutable cache for assets whose filenames are
# treated as stable. If a file at one of these paths changes, we rename it
# rather than overwrite (see image naming convention in CLAUDE.md).
/images/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# JS revalidates on every request so updates to project-relations.js
# (and any other site-wide JS) reach repeat visitors without a hard refresh.
/*.js
  Cache-Control: public, max-age=0, must-revalidate

# HTML — revalidate on every request so edits ship instantly.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
